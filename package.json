{
  "name": "@figma/my-make-file",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:widget": "vite build && mkdir -p public/widget && cp dist/widget/loader.js dist/widget/widget.js public/widget/",
    "server": "tsx watch server/index.ts",
    "dev": "npm run build:widget && concurrently -k -n vite,server -c blue,magenta \"vite\" \"tsx watch server/index.ts\"",
    "dev:fast": "concurrently -k -n vite,server -c blue,magenta \"vite\" \"tsx watch server/index.ts\"",
    "start": "npm run build && npm run build:widget && tsx server/index.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:3000",
    "tunnel:install": "command -v brew >/dev/null && brew install cloudflared || echo 'install manually: https://github.com/cloudflare/cloudflared/releases'"
  },
  "dependencies": {
